// Caixa "− valor +" reutilizavel. 'valor' e in-out (two-way com o estado),
// limitado entre 'mini' e 'maxi', com incremento 'passo'.
// Opcional: 'rotulo' (texto mostrado quando valor==0, ex.: "sem limite") e
// 'sufixo' (ex.: "s" para segundos).
import { Tema } from "../theme.slint";

export component Stepper inherits Rectangle {
    in-out property <int> valor;
    in property <int> mini: 0;
    in property <int> maxi: 100;
    in property <int> passo: 1;
    in property <string> rotulo: "";
    in property <string> sufixo: "";

    min-height: 34px;
    max-height: 34px;
    border-width: 1px;
    border-color: Tema.input-border;
    border-radius: 4px;
    background: Tema.input-bg;
    clip: true;

    HorizontalLayout {
        // −
        Rectangle {
            min-width: 32px;
            max-width: 32px;
            Text {
                x: (parent.width - self.width) / 2;
                y: (parent.height - self.height) / 2;
                text: "−";
                color: Tema.muted;
                font-size: 16px;
            }
            TouchArea {
                clicked => { root.valor = Math.max(root.mini, root.valor - root.passo); }
            }
        }
        // valor
        Text {
            horizontal-stretch: 1;
            text: (root.rotulo != "" && root.valor == 0) ? root.rotulo : "\{root.valor}\{root.sufixo}";
            horizontal-alignment: center;
            vertical-alignment: center;
            color: Tema.text;
            font-size: 14px;
            font-weight: 600;
        }
        // +
        Rectangle {
            min-width: 32px;
            max-width: 32px;
            Text {
                x: (parent.width - self.width) / 2;
                y: (parent.height - self.height) / 2;
                text: "+";
                color: Tema.muted;
                font-size: 16px;
            }
            TouchArea {
                clicked => { root.valor = Math.min(root.maxi, root.valor + root.passo); }
            }
        }
    }
}
