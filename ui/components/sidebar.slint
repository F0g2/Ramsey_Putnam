// Sidebar: parametros (Principal) e opcoes (Avançado), + botao Executar.
// Le/escreve o Estado. Dropdowns ainda via ComboBox (viram PopupWindow no 5b).
import { Tema } from "../theme.slint";
import { Estado } from "../estado.slint";
import { Textos } from "../strings.slint";
import { Stepper } from "stepper.slint";
import { Switch } from "switch.slint";
import { Dropdown } from "dropdown.slint";

export component Sidebar inherits Rectangle {
    callback executar;

    min-width: 268px;
    max-width: 268px;
    background: Tema.panel-bg;

    VerticalLayout {
        padding: 18px;
        spacing: 16px;

        Text {
            text: Estado.aba == 0 ? Textos.x.params : Textos.x.avancado;
            color: Tema.section;
            font-size: 11px;
            font-weight: 700;
        }

        // ===== Aba Principal =====
        if Estado.aba == 0: VerticalLayout {
            spacing: 16px;

            VerticalLayout {
                spacing: 7px;
                Text { text: Textos.x.metodo; color: Tema.label; font-size: 10px; font-weight: 600; }
                Dropdown {
                    opcoes: Textos.metodos;
                    indice <=> Estado.metodo;
                }
            }

            VerticalLayout {
                spacing: 5px;
                Text { text: "R( s , t )"; color: Tema.label; font-size: 10px; font-weight: 600; }
                HorizontalLayout {
                    spacing: 9px;
                    Stepper { valor <=> Estado.s; mini: 2; maxi: 9; }
                    Stepper { valor <=> Estado.t; mini: 2; maxi: 9; }
                }
                HorizontalLayout {
                    Text { horizontal-stretch: 1; text: "s"; horizontal-alignment: center; color: Tema.muted; font-size: 9px; }
                    Text { horizontal-stretch: 1; text: "t"; horizontal-alignment: center; color: Tema.muted; font-size: 9px; }
                }
            }

            VerticalLayout {
                spacing: 7px;
                Text { text: Textos.x.vertices; color: Tema.label; font-size: 10px; font-weight: 600; }
                Stepper { valor <=> Estado.n; mini: 1; maxi: 1000; }
            }
        }

        // ===== Aba Avançado =====
        if Estado.aba == 1: VerticalLayout {
            spacing: 16px;

            // quebra de simetria (toggle)
            HorizontalLayout {
                Text {
                    text: Textos.x.simetria;
                    color: Tema.label;
                    font-size: 10px;
                    font-weight: 600;
                    vertical-alignment: center;
                }
                Rectangle { }  // espacador
                Switch { ligado <=> Estado.sym; }
            }

            // tempo limite
            VerticalLayout {
                spacing: 7px;
                Text { text: Textos.x.tempo; color: Tema.label; font-size: 10px; font-weight: 600; }
                Stepper {
                    valor <=> Estado.timeout;
                    mini: 0;
                    maxi: 600;
                    passo: 30;
                    rotulo: Textos.x.semLimite;
                    sufixo: "s";
                }
            }

            // paralelismo
            VerticalLayout {
                spacing: 7px;
                Text { text: Textos.x.threads; color: Tema.label; font-size: 10px; font-weight: 600; }
                Stepper { valor <=> Estado.threads; mini: 1; maxi: 16; }
            }

            // backend SAT (so quando metodo == SAT)
            if Estado.metodo == 1: VerticalLayout {
                spacing: 7px;
                Text { text: Textos.x.backendSat; color: Tema.label; font-size: 10px; font-weight: 600; }
                Dropdown {
                    opcoes: Estado.backends;
                    indice <=> Estado.backend;
                }
            }

            // verbosidade
            VerticalLayout {
                spacing: 7px;
                Text { text: Textos.x.verbosidade; color: Tema.label; font-size: 10px; font-weight: 600; }
                Dropdown {
                    opcoes: Textos.verbosidades;
                    indice <=> Estado.verbosidade;
                }
            }
        }

        // espacador: empurra o botao para baixo
        Rectangle { }

        // Executar (primitivo, segue o tema)
        Rectangle {
            min-height: 44px;
            max-height: 44px;
            border-radius: 5px;
            background: Tema.btn-bg;
            Text {
                x: (parent.width - self.width) / 2;
                y: (parent.height - self.height) / 2;
                text: Textos.x.executar;
                color: Tema.btn-text;
                font-size: 13.5px;
                font-weight: 600;
            }
            TouchArea {
                clicked => { root.executar(); }
            }
        }
    }

    // divisoria à direita
    Rectangle {
        x: parent.width - 1px;
        width: 1px;
        background: Tema.border;
    }
}
