// Barra superior: abas (Principal/Avançado) à esquerda, seletores à direita.
// As abas sao primitivos (Rectangle+Text+TouchArea) para seguir os 4 temas.
// Os seletores usam ComboBox por ora (viram PopupWindow custom no Passo 5).
import { Tema } from "../theme.slint";
import { Estado } from "../estado.slint";
import { Textos } from "../strings.slint";
import { Dropdown } from "dropdown.slint";

// Uma aba estilo "sublinhado": rotulo em cima, barrinha accent embaixo.
// Empilha os dois com VerticalLayout (irmao vertical do HorizontalLayout).
component Aba inherits Rectangle {
    in property <string> rotulo;
    in property <bool> ativa;
    callback clicado;

    VerticalLayout {
        padding-left: 14px;
        padding-right: 14px;
        Text {
            text: root.rotulo;
            horizontal-alignment: center;
            vertical-alignment: center;
            // texto forte na aba ativa, apagado na inativa.
            color: ativa ? Tema.text : Tema.muted;
            font-size: 11.5px;
            font-weight: 600;
        }
        // Sublinhado: barrinha de 2px que so aparece (accent) na aba ativa.
        Rectangle {
            height: 2px;
            border-radius: 1px;
            background: ativa ? Tema.accent : transparent;
        }
    }
    TouchArea {
        clicked => { root.clicado(); }
    }
}

export component TopBar inherits Rectangle {
    min-height: 46px;
    max-height: 46px;
    background: Tema.topbar;

    HorizontalLayout {
        padding: 9px;
        spacing: 18px;

        // abas (sublinhado) à esquerda — sem caixa em volta
        HorizontalLayout {
            horizontal-stretch: 0;
            spacing: 6px;
            Aba {
                rotulo: Textos.x.tabPrincipal;
                ativa: Estado.aba == 0;
                clicado => { Estado.aba = 0; }
            }
            Aba {
                rotulo: Textos.x.tabAvancado;
                ativa: Estado.aba == 1;
                clicado => { Estado.aba = 1; }
            }
        }

        // espacador (empurra os seletores para a direita)
        Rectangle { }

        // seletores à direita
        HorizontalLayout {
            horizontal-stretch: 0;
            spacing: 9px;
            Text {
                text: Textos.x.lblIdioma;
                vertical-alignment: center;
                color: Tema.muted;
                font-size: 11px;
            }
            Dropdown {
                min-width: 128px;
                opcoes: Estado.idiomas;
                indice <=> Estado.idioma;
            }
            Text {
                text: Textos.x.lblTema;
                vertical-alignment: center;
                color: Tema.muted;
                font-size: 11px;
            }
            Dropdown {
                min-width: 128px;
                opcoes: Textos.temas;
                indice <=> Tema.id;
            }
        }
    }
}
