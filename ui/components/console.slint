// Nosso console: agora um MODELO de linhas coloridas (nao mais um texto unico).
// Cada linha tem um 'tom' que mapeia para uma cor do Tema.
import { Tema } from "../theme.slint";
import { Textos } from "../strings.slint";
import { LinhaConsole } from "../types.slint";

export component Console inherits Rectangle {
    in property <[LinhaConsole]> linhas;
    property <bool> cursor-on: true;

    // Pisca o cursor a cada ~0.5s (Timer e um elemento nao-visual).
    Timer {
        interval: 530ms;
        running: true;
        triggered => { root.cursor-on = !root.cursor-on; }
    }

    background: Tema.console-bg;
    border-width: 1px;
    border-color: Tema.border;
    border-radius: 6px;
    clip: true;

    flick := Flickable {
        x: 12px;
        y: 12px;
        width: parent.width - 24px;
        height: parent.height - 24px;
        viewport-width: self.width;
        viewport-height: col.preferred-height;

        col := VerticalLayout {
            width: flick.width;
            spacing: 2px;

            // dica quando vazio
            if root.linhas.length == 0: Text {
                text: Textos.x.vazio;
                color: Tema.console-dim;
                font-family: "DejaVu Sans Mono";
                font-size: 13px;
                wrap: word-wrap;
            }

            // uma Text por linha do modelo
            for ln in root.linhas: Text {
                text: ln.texto;
                color: ln.tom == 1 ? Tema.accent
                     : ln.tom == 2 ? Tema.console-text
                     : ln.tom == 3 ? Tema.console-dim
                     : Tema.text;
                font-family: "DejaVu Sans Mono";
                font-size: 13px;
                wrap: word-wrap;
            }

            // cursor piscando (so quando ha linhas)
            if root.linhas.length > 0: HorizontalLayout {
                alignment: start;
                Rectangle {
                    min-width: 7px;
                    max-width: 7px;
                    min-height: 15px;
                    max-height: 15px;
                    background: Tema.console-text;
                    opacity: root.cursor-on ? 1.0 : 0.0;
                }
            }
        }
    }
}
