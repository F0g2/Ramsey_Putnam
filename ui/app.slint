// PAINEL: importa os pedacos e os compoe. Le-se daqui o esqueleto do app.
import { Palette } from "std-widgets.slint";
import { Tema } from "theme.slint";
import { Textos } from "strings.slint";
import { LinhaConsole } from "types.slint";
import { TopBar } from "components/topbar.slint";
import { Sidebar } from "components/sidebar.slint";
import { Viz } from "components/viz.slint";
import { Console } from "components/console.slint";

// Re-exporta o Estado para o Rust poder acessa-lo (ui.global::<Estado>()).
export { Estado } from "estado.slint";

export component MainWindow inherits Window {
    title: "Ramsey GUI";
    icon: @image-url("assets/Penrose-dreieck.svg.png");
    preferred-width: 880px;
    preferred-height: 600px;
    background: Tema.win-bg;

    // Linhas do console, preenchidas pelo Rust.
    in property <[LinhaConsole]> linhas;
    // Disparado pelo botao Executar.
    callback rodar();

    // Espelha a base do tema para alinhar os widgets prontos ao claro/escuro.
    property <bool> escuro: Tema.escuro;
    init => {
        Palette.color-scheme = self.escuro ? ColorScheme.dark : ColorScheme.light;
    }
    changed escuro => {
        Palette.color-scheme = self.escuro ? ColorScheme.dark : ColorScheme.light;
    }

    VerticalLayout {
        TopBar { }

        HorizontalLayout {
            // sidebar (parametros + Executar)
            Sidebar {
                executar => { root.rodar(); }
            }

            // main (visualizacao + log)
            Rectangle {
                background: Tema.win-bg;
                VerticalLayout {
                    padding: 16px;
                    spacing: 12px;

                    Viz {
                        vertical-stretch: 1;
                    }

                    Text {
                        text: Textos.x.log;
                        color: Tema.label;
                        font-size: 10px;
                        font-weight: 600;
                    }

                    Console {
                        linhas: root.linhas;
                        min-height: 150px;
                        max-height: 150px;
                    }
                }
            }
        }
    }
}
