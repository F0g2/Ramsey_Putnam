// PAINEL: importa os pedacos e os compoe. Le-se daqui o esqueleto do app.
// O codigo pesado mora em theme.slint e components/.
import { Button, VerticalBox, HorizontalBox, ComboBox, Palette } from "std-widgets.slint";
import { Tema } from "theme.slint";
import { Console } from "components/console.slint";

export component MainWindow inherits Window {
    title: "Ramsey-Putnam";
    icon: @image-url("assets/Penrose-dreieck.svg.png");
    preferred-width: 800px;
    preferred-height: 600px;
    background: Tema.win-bg;

    // Texto do console, preenchido pelo Rust.
    in property <string> console-text;
    // Disparado pelo botao.
    callback rodar();

    // Espelha a base do tema para alinhar os widgets prontos ao claro/escuro.
    // (changed roda quando 'escuro' muda; mirror local de Tema.escuro.)
    property <bool> escuro: Tema.escuro;
    init => {
        Palette.color-scheme = self.escuro ? ColorScheme.dark : ColorScheme.light;
    }
    changed escuro => {
        Palette.color-scheme = self.escuro ? ColorScheme.dark : ColorScheme.light;
    }

    VerticalBox {
        HorizontalBox {
            alignment: end;
            Text {
                text: "Tema:";
                color: Tema.muted;
                vertical-alignment: center;
            }
            ComboBox {
                model: Tema.nomes;
                current-index <=> Tema.id;
            }
        }

        Console {
            texto: root.console-text;
        }

        HorizontalBox {
            alignment: center;
            Button {
                text: "Comecar calculo";
                clicked => { root.rodar(); }
            }
        }
    }
}
