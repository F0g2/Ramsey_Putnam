// Camada de apresentacao (markup, separado do Rust).
// O build.rs compila este arquivo; o Rust o consome via slint::include_modules!().

import { TextEdit, Button, VerticalBox, HorizontalBox } from "std-widgets.slint";

export component MainWindow inherits Window {
    title: "Ramsey-Putnam";
    preferred-width: 800px;
    preferred-height: 600px;

    // Texto preenchido pelo Rust; e o "stdout" da nossa janela.
    in property <string> console-text;

    // Evento disparado pelo botao; o Rust decide o que fazer (ver on_rodar).
    callback rodar();

    // VerticalBox empilha os filhos de cima para baixo, na ordem do codigo.
    VerticalBox {
        TextEdit {
            read-only: true;
            text: root.console-text;
        }
        // Por padrao um filho do VerticalBox estica na largura. Para deixar o
        // botao estreito, nos o colocamos num HorizontalBox com alignment:center,
        // que o mantem no tamanho natural do texto, centralizado.
        HorizontalBox {
            alignment: center;
            Button {
                text: "Comecar calculo";
                clicked => { root.rodar(); }
            }
        }
    }
}
